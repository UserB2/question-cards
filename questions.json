  "type": "일반 질문",
  "depth": 1,
  "source": "질문들"
 },
 {
  "id": 127,
  "text": "지금까지 가 본 곳 중 가장 인상 깊었던 여행지는 어디인가요?",
  "theme": "취향 저격",
  "type": "일반 질문",
  "depth": 1,
  "source": "질문들"
 },
