  "source": "질문들"
 },
 {
  "id": 62,
  "text": "우정에서 가장 가치 있게 여기는 것은 무엇인가요?",
  "theme": "마음 속 깊이",
  "type": "일반 질문",
  "depth": 2,
  "source": "질문들"
 },
 {
  "id": 63,
  "text": "가장 소중한 기억은 무엇인가요?",
  "theme": "추억 소환",
  "type": "일반 질문",
  "depth": 2,
  "source": "질문들"
 },
 {
  "id": 64,
  "text": "가장 끔찍했던 기억은 무엇인가요?",
  "theme": "추억 소환",
  "type": "일반 질문",
  "depth": 3,
  "source": "질문들"
 },
 {
  "id": 65,
  "text": "1년 뒤에 갑자기 죽는다는 걸 안다면, 지금 삶에서 무엇을 바꾸시겠어요? 왜요?",
  "theme": "마음 속 깊이",
  "type": "만약에..?",
  "depth": 3,
  "source": "질문들"
 },
 {
  "id": 66,
  "text": "당신에게 우정이란 무엇인가요?",
  "theme": "마음 속 깊이",
  "type": "일반 질문",
  "depth": 2,
  "source": "질문들"
 },
 {
  "id": 67,
  "text": "인생에서 사랑과 애정은 어떤 역할을 하나요?",
  "theme": "마음 속 깊이",
  "type": "일반 질문",
  "depth": 3,
  "source": "질문들"
 },
 {
  "id": 68,
  "text": "가족은 얼마나 가깝고 따뜻한 편인가요? 내 어린 시절이 남들보다 행복했다고 느끼나요?",
  "theme": "추억 소환",
  "type": "일반 질문",
  "depth": 3,
  "source": "질문들"
 },
 {
  "id": 69,
  "text": "어머니(또는 아버지)와의 관계는 어떤가요?",
  "theme": "마음 속 깊이",
  "type": "일반 질문",
  "depth": 3,
  "source": "질문들"
 },
 {
  "id": 70,
  "text": "'나는 (   )을/를 함께 나눌 수 있는 사람이 있었으면 좋겠다.' 빈칸을 채워 주세요.",
  "theme": "마음 속 깊이",
  "type": "빈칸 채우기",
  "depth": 3,
  "source": "질문들"
 },
 {
  "id": 71,
  "text": "옆 사람과 서로의 첫인상을 이야기해 주세요. 지금은 어떻게 달라졌나요?",
  "theme": "우리 사이",
  "type": "미션",
  "depth": 1,
  "source": "질문들"
 },
 {
  "id": 72,
  "text": "4분 동안 나의 인생 이야기를 최대한 자세히 들려주세요.",
  "theme": "마음 속 깊이",
  "type": "미션",
  "depth": 3,
  "source": "질문들"
 },
 {
  "id": 73,
  "text": "이 모임 사람들의 좋은 점을 한 사람당 하나씩 말해 주세요.",
  "theme": "우리 사이",
  "type": "미션",
  "depth": 2,
  "source": "질문들"
 },
 {
  "id": 74,
  "text": "개인적인 고민 하나를 나누고, 어떻게 하면 좋을지 모임 사람들의 조언을 들어 보세요.",
  "theme": "마음 속 깊이",
  "type": "미션",
  "depth": 3,
  "source": "질문들"
 },
 {
  "id": 75,
  "text": "인생에서 가장 난처했던(창피했던) 순간은 언제였나요?",
  "theme": "추억 소환",
  "type": "일반 질문",
  "depth": 2,
  "source": "질문들"
 },
 {
  "id": 76,
  "text": "마지막으로 다른 사람 앞에서 운 것은 언제였나요? 혼자 운 것은요?",
  "theme": "마음 속 깊이",
  "type": "일반 질문",
  "depth": 3,
  "source": "질문들"
 },
 {
  "id": 77,
  "text": "농담으로도 하면 안 된다고 생각하는 주제가 있나요?",
  "theme": "마음 속 깊이",
  "type": "일반 질문",
  "depth": 2,
  "source": "질문들"
 },
 {
  "id": 78,
  "text": "오늘 밤 아무에게도 말하지 못하고 죽는다면, 말하지 않은 것 중 무엇이 가장 후회될까요? 왜 아직 말하지 못했나요?",
  "theme": "마음 속 깊이",
  "type": "만약에..?",
  "depth": 3,
  "source": "질문들"
 },
 {
  "id": 79,
  "text": "가족 중 누군가를 잃는다면 누구의 죽음이 가장 감당하기 어려울 것 같나요? 왜요?",
  "theme": "마음 속 깊이",
  "type": "일반 질문",
  "depth": 3,
  "source": "질문들"
 },
 {
  "id": 80,
  "text": "인생에서 무엇에 가장 감사하나요?",
  "theme": "요즘 나는",
  "type": "일반 질문",
  "depth": 2,
  "source": "질문들"
 },
 {
  "id": 81,
  "text": "어린 시절 성장 환경에서 한 가지를 바꿀 수 있다면 무엇을 바꾸고 싶나요?",
  "theme": "추억 소환",
  "type": "만약에..?",
  "depth": 3,
  "source": "질문들"
 },
 {
  "id": 82,
  "text": "그리스도인은 의심을 해도 될까요?",
  "theme": "믿음 이야기",
  "type": "일반 질문",
  "depth": 2,
  "source": "질문들"
 },
 {
  "id": 83,
  "text": "우리는 왜 하나님을 사랑해야 할까요?",
  "theme": "믿음 이야기",
  "type": "일반 질문",
  "depth": 2,
  "source": "질문들"
 },
 {
  "id": 84,
  "text": "그리스도인이라면 꼭 전도를 해야 할까요?",
  "theme": "믿음 이야기",
  "type": "일반 질문",
  "depth": 2,
  "source": "질문들"
 },
 {
  "id": 85,
  "text": "전지전능하시고 사랑이신 하나님은 왜 세상의 불의와 사건·사고를 허락하실까요?",
  "theme": "믿음 이야기",
  "type": "일반 질문",
  "depth": 3,
  "source": "질문들"
 },
 {
  "id": 86,
  "text": "지옥은 필요한 것일까요?",
  "theme": "믿음 이야기",
  "type": "일반 질문",
  "depth": 3,
  "source": "질문들"
 },
 {
  "id": 87,
  "text": "그리스도인은 술을 마셔도 될까요?",
  "theme": "믿음 이야기",
  "type": "일반 질문",
  "depth": 2,
  "source": "질문들"
 },
 {
  "id": 88,
  "text": "그리스도인은 혼전 순결을 지켜야 할까요?",
  "theme": "믿음 이야기",
  "type": "일반 질문",
  "depth": 3,
  "source": "질문들"
 },
 {
  "id": 89,
  "text": "믿지 않는 사람과 결혼해도 될까요?",
  "theme": "믿음 이야기",
  "type": "일반 질문",
  "depth": 3,
  "source": "질문들"
 },
 {
  "id": 90,
  "text": "헌금과 십일조는 필수일까요?",
  "theme": "믿음 이야기",
  "type": "일반 질문",
  "depth": 2,
  "source": "질문들"
 },
 {
  "id": 91,
  "text": "그리스도인은 세상의 불의에 어떻게 반응해야 할까요?",
  "theme": "믿음 이야기",
  "type": "일반 질문",
  "depth": 3,
  "source": "질문들"
 },
 {
  "id": 92,
  "text": "나를 싫어하는 사람을, 그리고 내가 싫어하는 사람을 어떻게 대해야 할까요?",
  "theme": "믿음 이야기",
  "type": "일반 질문",
  "depth": 2,
  "source": "질문들"
 },
 {
  "id": 93,
  "text": "항상 기뻐하고 감사한다는 것은 무엇을 의미할까요?",
  "theme": "믿음 이야기",
  "type": "일반 질문",
  "depth": 2,
  "source": "질문들"
 },
 {
  "id": 94,
  "text": "무엇이 복된 삶일까요?",
  "theme": "믿음 이야기",
  "type": "일반 질문",
  "depth": 2,
  "source": "질문들"
 },
 {
  "id": 95,
  "text": "진로에 있어서 '하나님의 뜻'이라는 게 어떻게 존재할까요?",
  "theme": "믿음 이야기",
  "type": "일반 질문",
  "depth": 3,
  "source": "질문들"
 },
 {
  "id": 96,
  "text": "내 삶에서 어디까지가 내 행동의 결과이고 어디부터가 하나님의 인도하심일까요? 그 둘을 구분할 수 있을까요?",
  "theme": "믿음 이야기",
  "type": "일반 질문",
  "depth": 3,
  "source": "질문들"
 },
 {
  "id": 97,
  "text": "그리스도인에게 죄란 무엇일까요?",
  "theme": "믿음 이야기",
  "type": "일반 질문",
  "depth": 3,
  "source": "질문들"
 },
 {
  "id": 98,
  "text": "회개하면 그 죄에 대한 책임도 사라지는 걸까요?",
  "theme": "믿음 이야기",
  "type": "일반 질문",
  "depth": 3,
  "source": "질문들"
 },
 {
  "id": 99,
  "text": "우리는 왜 찬양할까요? 올바른 찬양의 형식이라는 게 있을까요?",
  "theme": "믿음 이야기",
  "type": "일반 질문",
  "depth": 2,
  "source": "질문들"
 },
 {
  "id": 100,
  "text": "예배의 목적은 무엇일까요? 잘못된 예배라는 게 존재할까요?",
  "theme": "믿음 이야기",
  "type": "일반 질문",
  "depth": 2,
  "source": "질문들"
 },
 {
  "id": 101,
  "text": "우리는 왜 기도해야 할까요?",
  "theme": "믿음 이야기",
  "type": "일반 질문",
  "depth": 2,
  "source": "질문들"
 },
 {
  "id": 102,
  "text": "하나님은 왜 어떤 기도에는 응답하시고 어떤 기도에는 응답하지 않으실까요?",
  "theme": "믿음 이야기",
  "type": "일반 질문",
  "depth": 3,
  "source": "질문들"
 },
 {
  "id": 103,
  "text": "하나님이 내 기도에 응답하셨는지 어떻게 알 수 있을까요?",
  "theme": "믿음 이야기",
  "type": "일반 질문",
  "depth": 3,
  "source": "질문들"
 },
 {
